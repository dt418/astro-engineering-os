{
  "name": "astro-orchestrator",
  "version": "0.1.0",
  "description": "Multi-agent orchestration runtime for astro-engineering-os",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "astro-orch": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin.js",
    "start:mcp": "node dist/mcp/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "lint:tests": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
