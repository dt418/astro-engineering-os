{
  "name": "astro-orchestrator",
  "version": "0.2.0",
  "description": "Multi-agent orchestration runtime for astro-engineering-os",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "astro-orch": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "lint:tests": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.2",
      "esbuild": ">=0.25.0"
    }
  }
}
