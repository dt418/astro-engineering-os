{
  "name": "astro-engineering-os",
  "version": "1.0.0",
  "description": "Engineering Operating System for Astro projects and AI coding agents",
  "layers": {
    "layer1": {
      "name": "Engineering OS",
      "components": [
        "skills",
        "governance", 
        "reviewers",
        "workflows",
        "adr",
        "templates"
      ]
    },
    "layer2": {
      "name": "Agent Orchestration",
      "components": [
        "orchestrator",
        "agents",
        "skill-routing",
        "workflow-coordination"
      ]
    },
    "layer3": {
      "name": "Engineering Harness",
      "components": [
        "validators",
        "auditors",
        "policies",
        "automation",
        "quality-gates"
      ],
      "status": "reserved"
    }
  },
  "orchestrator": {
    "name": "Astro Orchestrator",
    "file": "orchestrator/astro-orchestrator.md",
    "responsibilities": [
      "analyze incoming requests",
      "identify project type",
      "select skill packs",
      "select agents",
      "coordinate workflows",
      "aggregate outputs"
    ],
    "constraints": [
      "never implement features directly",
      "never perform reviews directly",
      "never generate architecture directly",
      "delegation is mandatory"
    ]
  },
  "agents": [
    {
      "name": "architect",
      "file": "agents/architect.md",
      "purpose": "Architecture design and strategic planning",
      "responsibilities": [
        "architecture decisions",
        "rendering strategy selection",
        "folder structure design",
        "data strategy definition"
      ]
    },
    {
      "name": "implementer",
      "file": "agents/implementer.md",
      "purpose": "Code implementation and refactoring",
      "responsibilities": [
        "feature implementation",
        "refactoring execution",
        "code generation",
        "test writing"
      ]
    },
    {
      "name": "reviewer",
      "file": "agents/reviewer.md",
      "purpose": "Code and architecture review",
      "responsibilities": [
        "architecture review",
        "performance review",
        "security review",
        "accessibility review"
      ]
    },
    {
      "name": "documentation",
      "file": "agents/documentation.md",
      "purpose": "Documentation generation and maintenance",
      "responsibilities": [
        "README generation",
        "ADR creation",
        "architecture documentation",
        "migration guides"
      ]
    }
  ],
  "skills": {
    "core": {
      "name": "astro-core",
      "file": "skills/astro-core/SKILL.md",
      "description": "Framework knowledge base for Astro",
      "modules": [
        "rendering",
        "content",
        "data",
        "performance",
        "cloudflare",
        "decision-frameworks",
        "tradeoff-analysis"
      ]
    },
    "packs": [
      {
        "name": "blog",
        "file": "skills/astro-core/packs/blog/SKILL.md",
        "extends": "astro-core",
        "domain": "blog and content sites"
      },
      {
        "name": "docs",
        "file": "skills/astro-core/packs/blog/SKILL.md",
        "extends": "astro-core",
        "domain": "documentation sites"
      },
      {
        "name": "saas",
        "file": "skills/astro-core/packs/saas/SKILL.md",
        "extends": "astro-core",
        "domain": "SaaS applications"
      },
      {
        "name": "ecommerce",
        "file": "skills/astro-core/packs/ecommerce/SKILL.md",
        "extends": "astro-core",
        "domain": "e-commerce applications"
      }
    ]
  },
  "governance": [
